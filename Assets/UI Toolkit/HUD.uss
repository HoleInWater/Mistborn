}

#Metal .unity-progress-bar__progress {
    -unity-background-image-tint-color: rgb(255, 255, 255);
    background-color: rgb(135, 135, 135);
}

#Metal .unity-progress-bar__background {
    background-color: rgb(0, 0, 0);
}
